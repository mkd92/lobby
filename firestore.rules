rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && ownerId != null && request.auth.uid == ownerId;
    }

    // Returns true when the requesting user has an accepted staff_lookup entry
    // for the given owner. The entry is written when staff accepts an invite.
    // Path: /staff_lookup/{staffUid}/owners/{ownerUid}
    function isActiveStaff(ownerId) {
      return isSignedIn() && ownerId != null &&
        exists(/databases/$(database)/documents/staff_lookup/$(request.auth.uid)/owners/$(ownerId));
    }

    function isManager(ownerId) {
      return isSignedIn() && ownerId != null &&
        exists(/databases/$(database)/documents/staff_lookup/$(request.auth.uid)/owners/$(ownerId)) &&
        get(/databases/$(database)/documents/staff_lookup/$(request.auth.uid)/owners/$(ownerId)).data.role == 'manager';
    }

    function canRead(ownerId) {
      return isOwner(ownerId) || isActiveStaff(ownerId);
    }

    function canWrite(ownerId) {
      return isOwner(ownerId) || isManager(ownerId);
    }

    // ── Owner profiles ─────────────────────────────────────────────────────

    match /owners/{ownerId} {
      allow read:  if canRead(ownerId);
      allow write: if isOwner(ownerId);
    }

    // ── Hostels, rooms & beds ──────────────────────────────────────────────

    match /hostels/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    match /rooms/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    match /beds/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    // ── Properties & Units ──────────────────────────────────────────────────

    match /properties/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    match /units/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    // ── Tenants / customers ────────────────────────────────────────────────

    match /tenants/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    // ── Leases ─────────────────────────────────────────────────────────────

    match /leases/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    match /property_leases/{docId} {
      allow read:          if canRead(resource.data.owner_id);
      allow create:        if canWrite(request.resource.data.owner_id);
      allow update, delete: if canWrite(resource.data.owner_id);
    }

    // ── Payments ───────────────────────────────────────────────────────────

    match /payments/{docId} {
      allow read:   if canRead(resource.data.owner_id);
      allow create: if canWrite(request.resource.data.owner_id);
      allow update: if canWrite(resource.data.owner_id);
      allow delete: if resource == null || canWrite(resource.data.get('owner_id', request.auth.uid));

      // Subcollections (e.g., transactions)
      match /{allPaths=**} {
        allow read: if canRead(get(/databases/$(database)/documents/payments/$(docId)).data.owner_id);
        allow write: if canWrite(get(/databases/$(database)/documents/payments/$(docId)).data.owner_id) ||
                      canWrite(request.resource.data.owner_id);
      }
    }

    // ── Accounting (Double-Entry) ──────────────────────────────────────────

    match /accounts/{docId} {
      allow read:   if canRead(resource.data.owner_id);
      allow create: if canWrite(request.resource.data.owner_id);
      allow update: if canWrite(resource.data.owner_id);
      allow delete: if false;
    }

    match /invoices/{docId} {
      allow read:   if canRead(resource.data.owner_id);
      allow create: if canWrite(request.resource.data.owner_id);
      allow update: if canWrite(resource.data.owner_id);
      allow delete: if resource == null || canWrite(resource.data.get('owner_id', request.auth.uid));
    }

    match /receipts/{docId} {
      allow read:   if canRead(resource.data.owner_id);
      allow create: if canWrite(request.resource.data.owner_id);
      allow update: if false;
      allow delete: if resource == null || canWrite(resource.data.get('owner_id', request.auth.uid));
    }

    match /journal_entries/{docId} {
      allow read:   if canRead(resource.data.owner_id);
      allow create: if canWrite(request.resource.data.owner_id);
      allow update: if false;
      allow delete: if false;
    }

    // ── Staff invites ──────────────────────────────────────────────────────
    // Owner sees their sent invites; staff sees invites addressed to them.

    match /staff/{staffId} {
      allow read: if isSignedIn() && (
        resource.data.owner_id == request.auth.uid ||
        resource.data.staff_email == request.auth.token.email
      );
      allow create: if isOwner(request.resource.data.owner_id);
      allow update: if isSignedIn() && (
        resource.data.owner_id == request.auth.uid ||
        resource.data.staff_email == request.auth.token.email
      );
      allow delete: if isSignedIn() && (
        resource.data.owner_id == request.auth.uid ||
        resource.data.staff_email == request.auth.token.email
      );
    }

    // ── Staff lookup (used by security rules above) ────────────────────────
    // /staff_lookup/{staffUid}/owners/{ownerUid}
    //   • Staff writes their own lookup when accepting an invite.
    //   • Owner can delete their entry from a staff member's lookup on revoke.

    match /staff_lookup/{staffUid}/owners/{ownerId} {
      allow read:   if request.auth.uid == staffUid || request.auth.uid == ownerId;
      allow create, update: if request.auth.uid == staffUid;
      allow delete: if request.auth.uid == staffUid || request.auth.uid == ownerId;
    }

  }
}
